# Point the dashboard at the deployed provider's read-only API (e.g. on Vercel).
# Leave unset for local dev to read the co-located SQLite file directly.
PROVIDER_API_URL="https://<your-provider-host>:8080"

# Only used when PROVIDER_API_URL is unset (local/single-host): path to the store.
# DB_PATH="../data/verigate.db"
