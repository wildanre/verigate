# --- Provider (VeriGate) ---
CROO_API_URL="https://api.croo.network"
CROO_WS_URL="wss://api.croo.network/ws"
CROO_SDK_KEY="croo_sk_...verigate..."

# CROO service IDs (from the Dashboard after registering the 3 services)
SVC_FACTCHECK_ID=""
SVC_SCHEMA_ID=""
SVC_GROUNDING_ID=""

# Verification engine — LLM (grounding + fact-check)
# Option A: direct Anthropic key (sets x-api-key)
# ANTHROPIC_API_KEY="sk-ant-..."
# Option B: Anthropic-compatible gateway (e.g. Manifest) — bearer auth token
ANTHROPIC_AUTH_TOKEN="mnfst__..."
ANTHROPIC_BASE_URL="https://app.manifest.build"
ANTHROPIC_MODEL="auto"

TAVILY_API_KEY="tvly-..."

# Storage
DB_PATH="./data/verigate.db"

# Optional: custom Base RPC for balance checks (SDK defaults to Base mainnet)
# BASE_RPC_URL="https://mainnet.base.org"

# --- Requester (DemoResearcher) — run as a SEPARATE process/env ---
# CROO_SDK_KEY="croo_sk_...demoresearcher..."
# CROO_TARGET_SERVICE_ID="<verigate-service-id>"
