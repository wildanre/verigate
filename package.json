{
  "name": "verigate",
  "version": "1.0.0",
  "description": "VeriGate — Verification-as-a-Service agent on CROO CAP",
  "main": "dist/provider.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.check.json",
    "start": "node dist/main.js",
    "provider": "tsx src/main.ts",
    "requester": "tsx demo/requester.ts",
    "mcp": "tsx src/mcp-server.ts"
  },
  "bin": {
